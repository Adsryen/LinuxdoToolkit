{
  "name": "LinuxdoToolkit",
  "version": "1.0.0",
  "description": "将 Linux.do 社区的油猴脚本整合为一站式浏览器扩展",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist node_modules"
  },
  "keywords": [
    "linuxdo",
    "browser-extension",
    "chrome-extension",
    "firefox-extension",
    "userscript",
    "tampermonkey",
    "greasemonkey",
    "community",
    "enhancement"
  ],
  "author": "Adsryen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adsryen/LinuxdoToolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Adsryen/LinuxdoToolkit/issues"
  },
  "homepage": "https://github.com/Adsryen/LinuxdoToolkit#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "sharp": "^0.35.2",
    "vite": "^5.0.12",
    "vitest": "^1.2.2"
  }
}
